{
  "group": {
    "default": {
      "targets": ["mcp-authz", "mcp-gateway"]
    }
  },
  "variable": {
    "TAG": {
      "default": "latest"
    },
    "SHA": {
      "default": "dev"
    }
  },
  "target": {
    "mcp-authz": {
      "dockerfile": "Dockerfile",
      "context": ".",
      "platforms": ["linux/amd64", "linux/arm64"],
      "args": {
        "VERSION": "${TAG}",
        "COMMIT": "${SHA}",
        "BIN": "mcp-authz"
      },
      "tags": [
        "ghcr.io/snapp-incubator/mcp-authz:${TAG}",
        "ghcr.io/snapp-incubator/mcp-authz:sha-${SHA}"
      ],
      "cache-from": [
        "type=gha,scope=mcp-authz"
      ],
      "cache-to": [
        "type=gha,mode=max,scope=mcp-authz"
      ]
    },
    "mcp-gateway": {
      "dockerfile": "Dockerfile",
      "context": ".",
      "platforms": ["linux/amd64", "linux/arm64"],
      "args": {
        "VERSION": "${TAG}",
        "COMMIT": "${SHA}",
        "BIN": "mcp-gateway"
      },
      "tags": [
        "ghcr.io/snapp-incubator/mcp-gateway:${TAG}",
        "ghcr.io/snapp-incubator/mcp-gateway:sha-${SHA}"
      ],
      "cache-from": [
        "type=gha,scope=mcp-gateway"
      ],
      "cache-to": [
        "type=gha,mode=max,scope=mcp-gateway"
      ]
    }
  }
}
